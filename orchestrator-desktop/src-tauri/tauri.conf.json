{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orchestrator",
  "version": "0.2.2",
  "identifier": "dev.safra.orchestrator",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": [
        "main-capabilities"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "Orchestrator",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "SafraPC",
    "homepage": "https://github.com/SafraPC/orchestrator",
    "license": "MIT",
    "copyright": "Copyright (c) 2026 Leandro Safra",
    "shortDescription": "Desktop orchestration for local Spring and JavaScript projects.",
    "longDescription": "Import local Spring and JavaScript projects, organize them into logical containers, start and stop services, and follow logs from a single desktop application.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "orchestrator-core-standalone.jar"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/dev.safra.orchestrator.metainfo.xml": "linux/dev.safra.orchestrator.metainfo.xml"
        }
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null
    }
  }
}
